{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Security audit findings",
  "type": "array",
  "items": {
    "oneOf": [
      {
        "type": "object",
        "properties": {
          "verdict": {
            "type": "string",
            "const": "confirmed"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "category": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "root_cause": {
            "type": "string",
            "minLength": 1
          },
          "intended_behavior": {
            "type": "string",
            "minLength": 1
          },
          "trace": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "object",
              "properties": {
                "kind": {
                  "type": "string",
                  "enum": [
                    "entrypoint",
                    "propagation",
                    "sink"
                  ]
                },
                "file": {
                  "type": "string",
                  "minLength": 1
                },
                "line": {
                  "type": "integer",
                  "minimum": 1
                },
                "scope": {
                  "type": "string",
                  "minLength": 1
                },
                "description": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "required": [
                "kind",
                "file",
                "line",
                "scope",
                "description"
              ],
              "additionalProperties": false
            }
          },
          "conditions": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "kind": {
                  "type": "string",
                  "enum": [
                    "authentication_level",
                    "authorization_role",
                    "user_interaction",
                    "system_configuration",
                    "network_routing",
                    "environmental_dependency",
                    "data_state",
                    "timing_dependency",
                    "third_party_dependency"
                  ]
                },
                "description": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "required": [
                "kind",
                "description"
              ],
              "additionalProperties": false
            }
          },
          "execution": {
            "type": "object",
            "properties": {
              "attacker_perspective": {
                "type": "string",
                "minLength": 1
              },
              "payloads": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "instructions": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "expected_result": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "attacker_perspective",
              "payloads",
              "instructions",
              "expected_result"
            ],
            "additionalProperties": false
          },
          "remediation": {
            "type": "object",
            "properties": {
              "strategy": {
                "type": "string",
                "minLength": 1
              },
              "code_changes": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "file": {
                      "type": "string",
                      "minLength": 1
                    },
                    "description": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "required": [
                    "file",
                    "description"
                  ],
                  "additionalProperties": false
                }
              }
            },
            "required": [
              "strategy",
              "code_changes"
            ],
            "additionalProperties": false
          },
          "severity": {
            "type": "object",
            "properties": {
              "likelihood": {
                "$ref": "#/$defs/scoredReason"
              },
              "impact": {
                "$ref": "#/$defs/scoredReason"
              },
              "overall": {
                "type": "string",
                "enum": [
                  "informational",
                  "low",
                  "medium",
                  "high",
                  "critical"
                ]
              }
            },
            "required": [
              "likelihood",
              "impact",
              "overall"
            ],
            "additionalProperties": false
          },
          "confidence": {
            "type": "object",
            "properties": {
              "score": {
                "type": "string",
                "enum": [
                  "medium",
                  "high"
                ]
              },
              "reason": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "score",
              "reason"
            ],
            "additionalProperties": false
          },
          "verification": {
            "type": "object",
            "properties": {
              "mode": {
                "type": "string",
                "enum": [
                  "source-confirmed",
                  "runtime-confirmed"
                ]
              },
              "evidence": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "mode",
              "evidence"
            ],
            "additionalProperties": false
          },
          "residual_risk": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "verdict",
          "title",
          "category",
          "description",
          "root_cause",
          "intended_behavior",
          "trace",
          "conditions",
          "execution",
          "remediation",
          "severity",
          "confidence",
          "verification",
          "residual_risk"
        ],
        "additionalProperties": false
      },
      {
        "type": "object",
        "properties": {
          "verdict": {
            "type": "string",
            "const": "rejected"
          },
          "candidate_title": {
            "type": "string",
            "minLength": 1
          },
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "evidence": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "verdict",
          "candidate_title",
          "reason",
          "evidence"
        ],
        "additionalProperties": false
      }
    ]
  },
  "$defs": {
    "scoredReason": {
      "type": "object",
      "properties": {
        "score": {
          "type": "string",
          "enum": [
            "informational",
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "score",
        "reason"
      ],
      "additionalProperties": false
    }
  }
}
