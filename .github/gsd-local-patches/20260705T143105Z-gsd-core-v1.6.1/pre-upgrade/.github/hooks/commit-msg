#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(git rev-parse --show-toplevel)"
cd "$ROOT_DIR"

MSG_FILE="${1:?commit message path is required}"
SUBJECT_LINE="$(sed -n '1p' "$MSG_FILE" | tr -d '\r')"

fail() {
    printf '[commit-msg] %s\n' "$1" >&2
    exit 1
}

if [[ -z "${SUBJECT_LINE// }" ]]; then
    fail 'Commit subject must not be empty.'
fi

if git diff --cached --name-only --diff-filter=ACMR | grep -Fxq 'versions.yaml'; then
    if ! grep -Eq '^feat\(v[0-9]+\.[0-9]+\.[0-9]+\): .+' "$MSG_FILE" \
        && ! grep -Eq '^feat\(crate-[^)]+\): .+' "$MSG_FILE"; then
        fail 'Version-managed commits must use the version-manager commit format.'
    fi

    if ! grep -Eq '^Version bump: [0-9]+\.[0-9]+\.[0-9]+ → [0-9]+\.[0-9]+\.[0-9]+$' "$MSG_FILE" \
        && ! grep -Eq '^Crate update: .+ → [0-9]+\.[0-9]+\.[0-9]+$' "$MSG_FILE"; then
        fail 'Version-managed commits must include a Version bump or Crate update line generated by version-manager.'
    fi
fi

exit 0